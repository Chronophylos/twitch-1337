# Twitch Bot Configuration
# Copy this file to .env and fill in your values

# Required: Bot username for posting stats
TWITCH_USERNAME=your_bot_username

# Required: OAuth access token
TWITCH_ACCESS_TOKEN=your_access_token_here

# Required: OAuth refresh token
TWITCH_REFRESH_TOKEN=your_refresh_token_here

# Required: Twitch application client ID
TWITCH_CLIENT_ID=your_client_id_here

# Required: Twitch application client secret
TWITCH_CLIENT_SECRET=your_client_secret_here

# Optional: Channel to monitor (default: euterheissgetraenk)
TWITCH_CHANNEL=euterheissgetraenk

# Optional: Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# Google Sheets Configuration (all optional - if not set, uses hardcoded schedules)
# Get these from Google Cloud Console: https://console.cloud.google.com/
# Create a service account and download the JSON key file

# Optional: Google Sheets spreadsheet ID (from the URL)
# Example: https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Optional: Sheet name within the spreadsheet (default: ScheduledMessages)
GOOGLE_SHEETS_SHEET_NAME=ScheduledMessages

# Optional: Path to service account JSON file
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json
