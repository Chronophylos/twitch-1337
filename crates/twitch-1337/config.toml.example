# Twitch 1337 Bot Configuration
# Copy this file to config.toml and fill in your credentials

[twitch]
# Twitch channel to monitor (without the # prefix)
channel = "your_channel"

# Bot's Twitch username
username = "your_bot_username"

# OAuth refresh token (used to get new access tokens automatically)
refresh_token = "your_refresh_token_here"

# Twitch application client ID
client_id = "your_client_id"

# Twitch application client secret
client_secret = "your_client_secret"

# Initial seed for IRC latency estimate in milliseconds (optional, default: 100)
# The bot measures actual latency via PING/PONG every 5 minutes and auto-adjusts.
# expected_latency = 89

# Twitch user IDs of hidden admins (can manage pings without being a mod)
# hidden_admins = ["12345678"]

# Twitch user IDs granted read-only viewer access to the web dashboard.
# viewer_allowlist = ["12345678", "87654321"]

# Twitch user ID with full dashboard access, including the settings page.
# Absent → settings page returns 403 for everyone. Single value for v1; a
# tiered permission system replaces it later.
# owner = "12345678"

# Optional: A separate channel for testing bot commands (broadcaster-only access)
# admin_channel = "my_test_channel"

# Optional: A dedicated channel where only `!ai` is reachable. Useful for
# moving AI command spam off the primary channel. Must differ from both
# `channel` and `admin_channel`.
# ai_channel = "my_bot_account"

# Cooldowns and ping policy are managed from the dashboard (`/settings`,
# owner-only). They live in `$DATA_DIR/settings.ron` after the first save.

# Optional: Aviationstack metadata enrichment for !track.
# The bot uses this at most once per newly tracked flight to fetch route,
# actual departure time, and to accept known flights before live ADS-B has data.
# After that, availability checks use the ADS-B pending-flight cadence; live
# tracking uses the ADS-B aggregator fallback chain.
# Free Aviationstack accounts have a small monthly request quota, so keep this
# disabled unless you have configured an API key.
# [aviationstack]
# enabled = false
# api_key = "your_aviationstack_api_key_here"
# base_url = "https://api.aviationstack.com/v1"
# timeout_secs = 5

# Optional: Suspend configuration
# Controls the default suspend duration applied when no explicit duration is given.
# Must be between 1 second and 604800 seconds (7 days).
# [suspend]
# default_duration_secs = 600  # Default suspend duration in seconds (default: 600 = 10 min)

# Optional: AI configuration for the !ai command
# If absent, the !ai command is disabled.
#
# Only the api_key is read from this file. Backend, base URL, model,
# memory caps, dreamer schedule, web/emote/media tools and every other
# AI knob now live in the dashboard at /settings (owner only) and persist
# to $DATA_DIR/settings.ron. Legacy [ai].* keys from earlier versions are
# migrated into settings.ron once on first v2 launch (sentinel:
# $DATA_DIR/.ai_migrated_v2).
#
# [ai]
# api_key = "sk-or-your_api_key"

# Optional: Scheduled messages configuration
# Add [[schedules]] sections to define scheduled messages.
# The bot watches config.toml for changes and reloads schedules automatically.
#
# Example schedule (uncomment to use):
#
# [[schedules]]
# name = "hydration"
# message = "Stay hydrated! DinkDonk"
# interval = "00:30"  # Post every 30 minutes (hh:mm format)
# enabled = true
#
# [[schedules]]
# name = "stream-reminder"
# message = "Don't forget to follow!"
# interval = "01:00"  # Post every hour
# # Optional: Only post during specific dates
# start_date = "2026-01-01T00:00:00"  # ISO 8601 format
# end_date = "2026-12-31T23:59:59"
# # Optional: Only post during specific daily time window (Europe/Berlin)
# active_time_start = "18:00"  # HH:MM format
# active_time_end = "23:00"
# enabled = true

# [web]                            # uncomment to enable the dashboard
# enabled = true
# bind_addr = "0.0.0.0:8080"
# public_url = "https://bot.example.com"
# session_secret = "<32+ bytes of hex>"
# session_ttl = "7d"
# mod_check_refresh = "5m"
